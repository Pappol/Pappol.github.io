---
import { SOCIALS, AUTHOR } from '../consts';
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container container--wide footer-inner">
    <p class="muted footer-copy">
      © {year} {AUTHOR}<!--
      EASTER EGG #5: this tiny dot is a hidden door to the easter-egg page.
      --><a href="/easter-eggs" class="secret-dot" aria-label="Secret">.</a>
    </p>
    <nav class="footer-links" aria-label="Social">
      <a href={SOCIALS.github} target="_blank" rel="me noopener">GitHub</a>
      <a href={SOCIALS.linkedin} target="_blank" rel="me noopener">LinkedIn</a>
      <button type="button" class="footer-link-btn" data-open-suggest>Suggest a post</button>
      <a href="/privacy">Privacy</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    margin-top: 2rem;
    padding-block: 2.5rem;
  }
  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .footer-copy {
    margin: 0;
    font-size: 0.85rem;
    color: var(--text-faint);
  }
  /* Looks like the period ending the sentence, but it's a link. */
  .secret-dot {
    color: inherit;
    text-decoration: none;
    cursor: text;
  }
  .secret-dot:hover {
    opacity: 1;
  }
  .footer-links {
    display: flex;
    gap: 1.3rem;
    font-size: 0.85rem;
    font-weight: 400;
    flex-wrap: wrap;
  }
  .footer-links a,
  .footer-link-btn {
    color: var(--text-soft);
    text-decoration: none;
  }
  .footer-links a:hover,
  .footer-link-btn:hover {
    color: var(--text);
    opacity: 1;
  }
  /* Strip default button chrome so it reads as a plain footer link. */
  .footer-link-btn {
    font: inherit;
    font-size: inherit;
    font-weight: inherit;
    background: none;
    border: none;
    padding: 0;
    margin: 0;
    cursor: pointer;
    transition: color var(--t-fast) var(--ease-pappol);
  }
</style>
