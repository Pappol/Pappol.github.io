---
import FormattedDate from './FormattedDate.astro';
export interface Props {
  href: string;
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
}
const { href, title, description, pubDate, tags = [] } = Astro.props;
---
<a class="card post-card" href={href}>
  <div class="post-card-meta">
    <FormattedDate date={pubDate} />
    {tags.length > 0 && <span class="tag">{tags[0]}</span>}
  </div>
  <h3 class="post-card-title">{title}</h3>
  <p class="muted post-card-desc">{description}</p>
  <span class="post-card-more">Read →</span>
</a>

<style>
  .post-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    height: 100%;
  }
  .post-card-meta {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    font-size: 0.85rem;
    color: var(--text-soft);
  }
  .post-card-title {
    margin: 0.1rem 0 0;
    font-size: 1.2rem;
  }
  .post-card-desc {
    margin: 0;
    font-size: 0.96rem;
    flex: 1;
  }
  .post-card-more {
    font-weight: 600;
    color: var(--accent-strong);
    font-size: 0.92rem;
    transition: transform var(--t-fast) var(--ease-pappol);
  }
  .post-card:hover .post-card-more {
    transform: translateX(3px);
  }
</style>
