---
import ThemeToggle from './ThemeToggle.astro';
import { NAV_LINKS, NICKNAME } from '../consts';
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---
<header class="site-header">
  <nav class="container container--wide nav" aria-label="Primary">
    <a href="/" class="brand" aria-label="Home">
      {NICKNAME}<span class="brand-dot" aria-hidden="true">.</span>
    </a>
    <div class="nav-links">
      {NAV_LINKS.map((l) => (
        <a href={l.href} class={isActive(l.href) ? 'nav-link is-active' : 'nav-link'}>
          {l.label}
        </a>
      ))}
      <ThemeToggle />
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: saturate(1.2) blur(8px);
  }
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 1.4rem;
  }
  .brand {
    font-weight: 600;
    font-size: 1.05rem;
    letter-spacing: -0.02em;
    color: var(--text);
    text-decoration: none;
  }
  .brand:hover {
    opacity: 1;
  }
  /* The brand dot stays monochrome — it simply inherits the ink colour. */
  .brand-dot {
    color: inherit;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.6rem;
  }
  .nav-link {
    color: var(--text-soft);
    text-decoration: none;
    font-weight: 400;
    font-size: 0.92rem;
    transition: color var(--t-fast) var(--ease-pappol);
  }
  .nav-link:hover,
  .nav-link.is-active {
    color: var(--text);
    opacity: 1;
  }
  @media (max-width: 30rem) {
    .nav-links { gap: 1.1rem; }
  }
</style>
