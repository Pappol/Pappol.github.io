---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import EmailSignup from '../components/EmailSignup.astro';
import { SOCIALS, NICKNAME } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const recent = posts.slice(0, 4);
const hasMore = posts.length > recent.length;
---

<BaseLayout>
  <!-- HERO -->
  <section class="hero">
    <img
      class="hero-photo"
      src="/images/me.jpeg"
      alt="Riccardo Parola"
      width="120"
      height="120"
      loading="eager"
    />
    <h1>I build the systems between raw data and useful intelligence.</h1>
    <p class="hero-bio muted">
      I'm Riccardo — aka {NICKNAME} — an Associate AI &amp; Data Engineer at PwC
      in Trento. I write about AI engineering, data pipelines, and getting
      machine learning to behave in production.
    </p>
    <div class="hero-actions">
      <a class="btn btn--primary" href="/blog">Read the blog</a>
      <a class="btn" href={SOCIALS.github} target="_blank" rel="me noopener">GitHub</a>
      <a class="btn" href={SOCIALS.linkedin} target="_blank" rel="me noopener">LinkedIn</a>
    </div>
  </section>

  <!-- RECENT WRITING -->
  <section class="section">
    <h2 class="section-label">Recent Publications</h2>
    {
      recent.length === 0 ? (
        <p class="muted">No posts yet — check back soon.</p>
      ) : (
        <ul class="pub-list">
          {recent.map((p) => (
            <li>
              <a class="pub" href={`/blog/${p.id}/`}>
                <div class="pub-text">
                  <p class="pub-meta">
                    <FormattedDate date={p.data.pubDate} />
                    {p.data.tags[0] && (
                      <>
                        <span class="dot">·</span>
                        <span class="tag">{p.data.tags[0]}</span>
                      </>
                    )}
                  </p>
                  <h3 class="pub-title">{p.data.title}</h3>
                </div>
                {p.data.heroImage && (
                  <div class="pub-thumb">
                    <img
                      src={p.data.heroImage}
                      alt={p.data.heroImageAlt ?? ''}
                      loading="lazy"
                    />
                  </div>
                )}
              </a>
            </li>
          ))}
        </ul>
      )
    }

    {
      hasMore && (
        <div class="view-more">
          <a class="btn btn--block" href="/blog">
            View More
          </a>
        </div>
      )
    }
  </section>

  <!-- EMAIL -->
  <section class="section">
    <EmailSignup />
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: 1.5rem 1rem;
    max-width: 40rem;
  }
  .hero-photo {
    width: 180px;
    height: 180px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--border);
    margin-bottom: 1.6rem;
  }
  .hero h1 {
    margin: 0 0 1.2rem;
  }
  .hero-bio {
    font-size: 1.08rem;
    line-height: 1.7;
    margin: 0;
  }
  .hero-actions {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-top: 1.8rem;
  }

  @media (max-width: 480px) {
    .hero-actions {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  .section-label {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text-soft);
    margin: 0 0 1.5rem;
  }

  .pub-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .pub {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.1rem 0;
    text-decoration: none;
    color: inherit;
    border-bottom: 1px solid var(--border);
  }
  .pub:hover {
    opacity: 1;
  }
  .pub:hover .pub-title {
    color: var(--text-soft);
  }
  .pub-text {
    min-width: 0;
  }
  .pub-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 0.4rem;
    font-size: 0.8rem;
    color: var(--text-faint);
  }
  .pub-meta .dot {
    opacity: 0.6;
  }
  .pub-title {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 500;
    line-height: 1.4;
    transition: color var(--t-fast) var(--ease-pappol);
  }
  .pub-thumb {
    flex: none;
    width: 116px;
    height: 76px;
    border-radius: var(--radius-sm);
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .pub-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .view-more {
    margin-top: 2rem;
  }

  @media (max-width: 32rem) {
    .pub-thumb {
      width: 84px;
      height: 60px;
    }
  }
</style>
