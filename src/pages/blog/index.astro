---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Blog" description="All articles by Riccardo Parola.">
  <header class="page-head">
    <h1>Blog</h1>
    <p class="muted">Everything I've published, newest first.</p>
  </header>

  {
    posts.length === 0 ? (
      <p class="muted">No posts yet — check back soon.</p>
    ) : (
      <ul class="post-list">
        {posts.map((p) => (
          <li class="post-list-item">
            <a href={`/blog/${p.id}/`} class="post-list-link">
              <div class="post-list-body">
                <p class="post-list-meta">
                  <FormattedDate date={p.data.pubDate} />
                  {p.data.tags.slice(0, 2).map((t) => (
                    <>
                      <span class="dot">·</span>
                      <span class="tag">{t}</span>
                    </>
                  ))}
                </p>
                <h2 class="post-list-title">{p.data.title}</h2>
                <p class="muted post-list-desc">{p.data.description}</p>
              </div>
              {p.data.heroImage && (
                <div class="post-list-thumb">
                  <img
                    src={p.data.heroImage}
                    alt={p.data.heroImageAlt ?? ''}
                    loading="lazy"
                  />
                </div>
              )}
            </a>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>

<style>
  .page-head {
    margin-bottom: 3rem;
  }
  .page-head h1 {
    margin: 0 0 0.5rem;
  }
  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }
  .post-list-item {
    border-top: 1px solid var(--border);
  }
  .post-list-item:last-child {
    border-bottom: 1px solid var(--border);
  }
  .post-list-link {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.6rem 0;
    text-decoration: none;
    color: inherit;
  }
  .post-list-link:hover {
    opacity: 1;
  }
  .post-list-link:hover .post-list-title {
    color: var(--text-soft);
  }
  .post-list-body {
    min-width: 0;
  }
  .post-list-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin: 0 0 0.5rem;
    color: var(--text-faint);
    font-size: 0.8rem;
  }
  .post-list-meta .dot {
    opacity: 0.6;
  }
  .post-list-title {
    margin: 0 0 0.5rem;
    font-size: 1.25rem;
    font-weight: 550;
    transition: color var(--t-fast) var(--ease-pappol);
  }
  .post-list-desc {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
  }
  .post-list-thumb {
    flex: none;
    width: 132px;
    height: 88px;
    border-radius: var(--radius-sm);
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .post-list-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  @media (max-width: 32rem) {
    .post-list-thumb {
      display: none;
    }
  }
</style>
